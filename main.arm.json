{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.41.2.15936",
      "templateHash": "12309267341856359414"
    }
  },
  "parameters": {
    "functionAppName": {
      "type": "string",
      "minLength": 2,
      "maxLength": 60,
      "metadata": {
        "description": "Name of the Azure Function App. Must be globally unique."
      }
    },
    "storageAccountName": {
      "type": "string",
      "minLength": 3,
      "maxLength": 24,
      "metadata": {
        "description": "Storage Account for Function App runtime state. Lowercase, no hyphens, globally unique."
      }
    },
    "appInsightsName": {
      "type": "string",
      "metadata": {
        "description": "Application Insights instance name for monitoring and alerting."
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Azure region for all resources. Defaults to the resource group location."
      }
    },
    "pythonVersion": {
      "type": "string",
      "defaultValue": "3.12",
      "allowedValues": [
        "3.10",
        "3.11",
        "3.12"
      ],
      "metadata": {
        "description": "Python runtime version. 3.12 RECOMMENDED for performance and security patches."
      }
    },
    "managedIdentityType": {
      "type": "string",
      "defaultValue": "SystemAssigned",
      "allowedValues": [
        "SystemAssigned",
        "UserAssigned"
      ],
      "metadata": {
        "description": "Managed identity for ADX and Key Vault authentication. SystemAssigned = simpler, auto-managed lifecycle. UserAssigned = more control, shared across resources, survives redeploys."
      }
    },
    "userAssignedIdentityResourceId": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Full resource ID of the User Assigned Managed Identity. Required when managedIdentityType is UserAssigned. Format: /subscriptions/.../resourceGroups/.../providers/Microsoft.ManagedIdentity/userAssignedIdentities/<name>"
      }
    },
    "userAssignedPrincipalId": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Principal (Object) ID of the User Assigned Managed Identity. Required when managedIdentityType is UserAssigned. Find in Portal: UAMI resource > Properties > Principal ID."
      }
    },
    "userAssignedClientId": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Client (Application) ID of the User Assigned Managed Identity. Required when managedIdentityType is UserAssigned. Find in Portal: UAMI resource > Properties > Client ID. Used by the Python SDK to select the correct identity at runtime."
      }
    },
    "keyVaultOption": {
      "type": "string",
      "defaultValue": "create",
      "allowedValues": [
        "none",
        "existing",
        "create"
      ],
      "metadata": {
        "description": "Secret management strategy for the Netskope API token. \"none\" = plaintext app setting (dev/test ONLY). \"existing\" = reference a secret already stored in your Key Vault. \"create\" = deploy a new Key Vault and store the token. RECOMMENDED: \"existing\" or \"create\" for production."
      }
    },
    "keyVaultName": {
      "type": "string",
      "defaultValue": "",
      "minLength": 0,
      "maxLength": 24,
      "metadata": {
        "description": "Key Vault name. For \"create\": name for the new vault (globally unique, 3-24 chars). For \"existing\": name of your vault (must be in the same resource group, RBAC authorization must be enabled). Required when keyVaultOption is not \"none\"."
      }
    },
    "keyVaultSecretName": {
      "type": "string",
      "defaultValue": "NetskopeApiToken",
      "metadata": {
        "description": "Secret name in Key Vault holding the Netskope API token."
      }
    },
    "keyVaultSku": {
      "type": "string",
      "defaultValue": "standard",
      "allowedValues": [
        "standard",
        "premium"
      ],
      "metadata": {
        "description": "Key Vault SKU. \"standard\" is sufficient for secret storage. \"premium\" adds HSM-backed keys (not needed here)."
      }
    },
    "adxClusterUri": {
      "type": "string",
      "metadata": {
        "description": "ADX cluster query endpoint. Example: https://mycluster.eastus.kusto.windows.net"
      }
    },
    "adxDatabaseName": {
      "type": "string",
      "metadata": {
        "description": "Target ADX database name for Netskope data ingestion."
      }
    },
    "netskopeHostname": {
      "type": "string",
      "metadata": {
        "description": "Netskope tenant hostname. Example: mytenant.goskope.com"
      }
    },
    "netskopeApiToken": {
      "type": "securestring",
      "metadata": {
        "description": "Netskope REST API v2 token. Required when keyVaultOption is \"none\" or \"create\". Not used when \"existing\" (token already in Key Vault)."
      }
    },
    "netskopeIndex": {
      "type": "string",
      "defaultValue": "NetskopeADX",
      "metadata": {
        "description": "Iterator index name shared across all endpoints. Netskope scopes the cursor per endpoint type automatically. WARNING: Changing after initial deployment may cause data gaps or duplicates."
      }
    },
    "logLevel": {
      "type": "string",
      "defaultValue": "INFO",
      "allowedValues": [
        "DEBUG",
        "INFO",
        "WARNING",
        "ERROR"
      ],
      "metadata": {
        "description": "Python application log level. DEBUG = very verbose (troubleshooting). INFO = normal operations (RECOMMENDED). WARNING/ERROR = quiet."
      }
    },
    "detailedKustoLogging": {
      "type": "string",
      "defaultValue": "No",
      "allowedValues": [
        "Yes",
        "No"
      ],
      "metadata": {
        "description": "Enable verbose Azure Kusto SDK logging. Yes = detailed ADX connection and ingestion logs (troubleshooting). No = quiet (RECOMMENDED for normal operations)."
      }
    },
    "ingestEventsPage": {
      "type": "string",
      "defaultValue": "Yes",
      "allowedValues": [
        "Yes",
        "No"
      ],
      "metadata": {
        "description": "Web page access events. Typically the highest-volume stream. RECOMMENDED for web security monitoring."
      }
    },
    "ingestEventsApplication": {
      "type": "string",
      "defaultValue": "Yes",
      "allowedValues": [
        "Yes",
        "No"
      ],
      "metadata": {
        "description": "Cloud app activity events. RECOMMENDED for SaaS security and shadow IT detection."
      }
    },
    "ingestEventsAudit": {
      "type": "string",
      "defaultValue": "Yes",
      "allowedValues": [
        "Yes",
        "No"
      ],
      "metadata": {
        "description": "Netskope admin audit trail. RECOMMENDED for compliance and change tracking."
      }
    },
    "ingestEventsInfrastructure": {
      "type": "string",
      "defaultValue": "No",
      "allowedValues": [
        "Yes",
        "No"
      ],
      "metadata": {
        "description": "Infrastructure events (CASB/SWG platform logs). Enable for platform-level diagnostics."
      }
    },
    "ingestEventsNetwork": {
      "type": "string",
      "defaultValue": "No",
      "allowedValues": [
        "Yes",
        "No"
      ],
      "metadata": {
        "description": "Network events (firewall, IPS). Enable if using Netskope Intelligent SSE."
      }
    },
    "ingestEventsConnection": {
      "type": "string",
      "defaultValue": "No",
      "allowedValues": [
        "Yes",
        "No"
      ],
      "metadata": {
        "description": "Connection events (tunnel, ZTNA). Enable for zero-trust network access monitoring."
      }
    },
    "ingestEventsEndpoint": {
      "type": "string",
      "defaultValue": "No",
      "allowedValues": [
        "Yes",
        "No"
      ],
      "metadata": {
        "description": "Endpoint events (NPA client, device posture). Enable if using Netskope Private Access."
      }
    },
    "ingestEventsIncident": {
      "type": "string",
      "defaultValue": "No",
      "allowedValues": [
        "Yes",
        "No"
      ],
      "metadata": {
        "description": "Incident events. Enable for security incident correlation. May not be available on all Netskope licenses."
      }
    },
    "ingestAlertsRemediation": {
      "type": "string",
      "defaultValue": "No",
      "allowedValues": [
        "Yes",
        "No"
      ],
      "metadata": {
        "description": "Remediation action alerts (quarantine, block, coach). Low volume."
      }
    },
    "ingestAlertsCompromisedCredential": {
      "type": "string",
      "defaultValue": "No",
      "allowedValues": [
        "Yes",
        "No"
      ],
      "metadata": {
        "description": "Compromised credential alerts. RECOMMENDED for identity security. Requires threat protection license."
      }
    },
    "ingestAlertsUba": {
      "type": "string",
      "defaultValue": "No",
      "allowedValues": [
        "Yes",
        "No"
      ],
      "metadata": {
        "description": "User Behavior Analytics (UBA) alerts. Enable for insider threat detection."
      }
    },
    "ingestAlertsSecurityAssessment": {
      "type": "string",
      "defaultValue": "No",
      "allowedValues": [
        "Yes",
        "No"
      ],
      "metadata": {
        "description": "Security posture assessment alerts. Enable for CSPM use cases."
      }
    },
    "ingestAlertsQuarantine": {
      "type": "string",
      "defaultValue": "No",
      "allowedValues": [
        "Yes",
        "No"
      ],
      "metadata": {
        "description": "Quarantine action alerts. Enable to track file quarantine events."
      }
    },
    "ingestAlertsPolicy": {
      "type": "string",
      "defaultValue": "Yes",
      "allowedValues": [
        "Yes",
        "No"
      ],
      "metadata": {
        "description": "Real-time policy violation alerts. RECOMMENDED — core security alerting stream."
      }
    },
    "ingestAlertsMalware": {
      "type": "string",
      "defaultValue": "Yes",
      "allowedValues": [
        "Yes",
        "No"
      ],
      "metadata": {
        "description": "Malware detection alerts. RECOMMENDED for threat protection. Includes cloud and inline scan results."
      }
    },
    "ingestAlertsMalsite": {
      "type": "string",
      "defaultValue": "Yes",
      "allowedValues": [
        "Yes",
        "No"
      ],
      "metadata": {
        "description": "Malicious site (malsite) alerts. RECOMMENDED for web threat protection."
      }
    },
    "ingestAlertsDlp": {
      "type": "string",
      "defaultValue": "Yes",
      "allowedValues": [
        "Yes",
        "No"
      ],
      "metadata": {
        "description": "Data Loss Prevention (DLP) alerts. RECOMMENDED for data protection compliance."
      }
    },
    "ingestAlertsCtep": {
      "type": "string",
      "defaultValue": "No",
      "allowedValues": [
        "Yes",
        "No"
      ],
      "metadata": {
        "description": "Client Traffic Exploit Prevention (CTEP) alerts. Enable if using advanced threat protection."
      }
    },
    "ingestAlertsWatchlist": {
      "type": "string",
      "defaultValue": "No",
      "allowedValues": [
        "Yes",
        "No"
      ],
      "metadata": {
        "description": "Watchlist alerts. Enable to track activity from monitored users/entities."
      }
    },
    "ingestAlertsDevice": {
      "type": "string",
      "defaultValue": "No",
      "allowedValues": [
        "Yes",
        "No"
      ],
      "metadata": {
        "description": "Device classification alerts. Enable for endpoint compliance. May not be available on all licenses."
      }
    },
    "ingestAlertsContent": {
      "type": "string",
      "defaultValue": "No",
      "allowedValues": [
        "Yes",
        "No"
      ],
      "metadata": {
        "description": "Content classification alerts (file/object). Enable for data-centric security. May not be available on all licenses."
      }
    }
  },
  "variables": {
    "hostingPlanName": "[format('{0}-plan', parameters('functionAppName'))]",
    "resourceTags": {
      "Purpose": "Netskope-Log-Segregation"
    },
    "isUserAssigned": "[equals(parameters('managedIdentityType'), 'UserAssigned')]",
    "identityBlock": "[if(variables('isUserAssigned'), createObject('type', 'UserAssigned', 'userAssignedIdentities', createObject(format('{0}', parameters('userAssignedIdentityResourceId')), createObject())), createObject('type', 'SystemAssigned'))]",
    "kvSecretUri": "[format('https://{0}{1}/secrets/{2}/', parameters('keyVaultName'), environment().suffixes.keyvaultDns, parameters('keyVaultSecretName'))]",
    "netskopeTokenSetting": "[if(not(equals(parameters('keyVaultOption'), 'none')), format('@Microsoft.KeyVault(SecretUri={0})', variables('kvSecretUri')), parameters('netskopeApiToken'))]",
    "kvSecretsUserRoleId": "4633458b-17de-408a-b874-0445c86b69e6"
  },
  "resources": [
    {
      "type": "Microsoft.Storage/storageAccounts",
      "apiVersion": "2024-01-01",
      "name": "[parameters('storageAccountName')]",
      "location": "[parameters('location')]",
      "tags": "[variables('resourceTags')]",
      "sku": {
        "name": "Standard_LRS"
      },
      "kind": "StorageV2",
      "properties": {
        "supportsHttpsTrafficOnly": true,
        "minimumTlsVersion": "TLS1_2",
        "allowBlobPublicAccess": false
      }
    },
    {
      "type": "Microsoft.Insights/components",
      "apiVersion": "2020-02-02",
      "name": "[parameters('appInsightsName')]",
      "location": "[parameters('location')]",
      "tags": "[variables('resourceTags')]",
      "kind": "web",
      "properties": {
        "Application_Type": "web",
        "Request_Source": "rest"
      }
    },
    {
      "type": "Microsoft.Web/serverfarms",
      "apiVersion": "2024-04-01",
      "name": "[variables('hostingPlanName')]",
      "location": "[parameters('location')]",
      "tags": "[variables('resourceTags')]",
      "kind": "linux",
      "sku": {
        "name": "Y1",
        "tier": "Dynamic"
      },
      "properties": {
        "reserved": true
      }
    },
    {
      "type": "Microsoft.Web/sites",
      "apiVersion": "2024-04-01",
      "name": "[parameters('functionAppName')]",
      "location": "[parameters('location')]",
      "tags": "[variables('resourceTags')]",
      "kind": "functionapp,linux",
      "identity": "[variables('identityBlock')]",
      "properties": {
        "serverFarmId": "[resourceId('Microsoft.Web/serverfarms', variables('hostingPlanName'))]",
        "reserved": true,
        "httpsOnly": true,
        "siteConfig": {
          "linuxFxVersion": "[format('PYTHON|{0}', parameters('pythonVersion'))]",
          "ftpsState": "Disabled",
          "minTlsVersion": "1.2",
          "appSettings": [
            {
              "name": "FUNCTIONS_EXTENSION_VERSION",
              "value": "~4"
            },
            {
              "name": "FUNCTIONS_WORKER_RUNTIME",
              "value": "python"
            },
            {
              "name": "AzureWebJobsStorage",
              "value": "[format('DefaultEndpointsProtocol=https;AccountName={0};AccountKey={1};EndpointSuffix={2}', parameters('storageAccountName'), listKeys(resourceId('Microsoft.Storage/storageAccounts', parameters('storageAccountName')), '2024-01-01').keys[0].value, environment().suffixes.storage)]"
            },
            {
              "name": "APPLICATIONINSIGHTS_CONNECTION_STRING",
              "value": "[reference(resourceId('Microsoft.Insights/components', parameters('appInsightsName')), '2020-02-02').ConnectionString]"
            },
            {
              "name": "ADX_CLUSTER_URI",
              "value": "[parameters('adxClusterUri')]"
            },
            {
              "name": "ADX_DATABASE",
              "value": "[parameters('adxDatabaseName')]"
            },
            {
              "name": "NetskopeHostname",
              "value": "[parameters('netskopeHostname')]"
            },
            {
              "name": "NetskopeApiToken",
              "value": "[variables('netskopeTokenSetting')]"
            },
            {
              "name": "NetskopeIndex",
              "value": "[parameters('netskopeIndex')]"
            },
            {
              "name": "MANAGED_IDENTITY_CLIENT_ID",
              "value": "[if(variables('isUserAssigned'), parameters('userAssignedClientId'), '')]"
            },
            {
              "name": "LOG_LEVEL",
              "value": "[parameters('logLevel')]"
            },
            {
              "name": "AZURE_LOG_LEVEL",
              "value": "[if(equals(parameters('detailedKustoLogging'), 'Yes'), 'INFO', 'WARNING')]"
            },
            {
              "name": "IngestEventsPage",
              "value": "[parameters('ingestEventsPage')]"
            },
            {
              "name": "IngestEventsApplication",
              "value": "[parameters('ingestEventsApplication')]"
            },
            {
              "name": "IngestEventsAudit",
              "value": "[parameters('ingestEventsAudit')]"
            },
            {
              "name": "IngestEventsInfrastructure",
              "value": "[parameters('ingestEventsInfrastructure')]"
            },
            {
              "name": "IngestEventsNetwork",
              "value": "[parameters('ingestEventsNetwork')]"
            },
            {
              "name": "IngestEventsConnection",
              "value": "[parameters('ingestEventsConnection')]"
            },
            {
              "name": "IngestEventsEndpoint",
              "value": "[parameters('ingestEventsEndpoint')]"
            },
            {
              "name": "IngestEventsIncident",
              "value": "[parameters('ingestEventsIncident')]"
            },
            {
              "name": "IngestAlertsRemediation",
              "value": "[parameters('ingestAlertsRemediation')]"
            },
            {
              "name": "IngestAlertsCompromisedCredential",
              "value": "[parameters('ingestAlertsCompromisedCredential')]"
            },
            {
              "name": "IngestAlertsUba",
              "value": "[parameters('ingestAlertsUba')]"
            },
            {
              "name": "IngestAlertsSecurityAssessment",
              "value": "[parameters('ingestAlertsSecurityAssessment')]"
            },
            {
              "name": "IngestAlertsQuarantine",
              "value": "[parameters('ingestAlertsQuarantine')]"
            },
            {
              "name": "IngestAlertsPolicy",
              "value": "[parameters('ingestAlertsPolicy')]"
            },
            {
              "name": "IngestAlertsMalware",
              "value": "[parameters('ingestAlertsMalware')]"
            },
            {
              "name": "IngestAlertsMalsite",
              "value": "[parameters('ingestAlertsMalsite')]"
            },
            {
              "name": "IngestAlertsDlp",
              "value": "[parameters('ingestAlertsDlp')]"
            },
            {
              "name": "IngestAlertsCtep",
              "value": "[parameters('ingestAlertsCtep')]"
            },
            {
              "name": "IngestAlertsWatchlist",
              "value": "[parameters('ingestAlertsWatchlist')]"
            },
            {
              "name": "IngestAlertsDevice",
              "value": "[parameters('ingestAlertsDevice')]"
            },
            {
              "name": "IngestAlertsContent",
              "value": "[parameters('ingestAlertsContent')]"
            }
          ]
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.Insights/components', parameters('appInsightsName'))]",
        "[resourceId('Microsoft.Web/serverfarms', variables('hostingPlanName'))]",
        "[resourceId('Microsoft.Storage/storageAccounts', parameters('storageAccountName'))]"
      ]
    },
    {
      "condition": "[equals(parameters('keyVaultOption'), 'create')]",
      "type": "Microsoft.KeyVault/vaults",
      "apiVersion": "2023-07-01",
      "name": "[parameters('keyVaultName')]",
      "location": "[parameters('location')]",
      "tags": "[variables('resourceTags')]",
      "properties": {
        "tenantId": "[subscription().tenantId]",
        "sku": {
          "family": "A",
          "name": "[parameters('keyVaultSku')]"
        },
        "enableRbacAuthorization": true,
        "enableSoftDelete": true,
        "softDeleteRetentionInDays": 90,
        "enablePurgeProtection": true
      }
    },
    {
      "condition": "[equals(parameters('keyVaultOption'), 'create')]",
      "type": "Microsoft.KeyVault/vaults/secrets",
      "apiVersion": "2023-07-01",
      "name": "[format('{0}/{1}', parameters('keyVaultName'), parameters('keyVaultSecretName'))]",
      "properties": {
        "value": "[parameters('netskopeApiToken')]",
        "contentType": "Netskope REST API v2 token"
      },
      "dependsOn": [
        "[resourceId('Microsoft.KeyVault/vaults', parameters('keyVaultName'))]"
      ]
    },
    {
      "condition": "[equals(parameters('keyVaultOption'), 'create')]",
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "scope": "[resourceId('Microsoft.KeyVault/vaults', parameters('keyVaultName'))]",
      "name": "[guid(resourceId('Microsoft.KeyVault/vaults', parameters('keyVaultName')), variables('kvSecretsUserRoleId'), parameters('functionAppName'))]",
      "properties": {
        "roleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', variables('kvSecretsUserRoleId'))]",
        "principalId": "[if(variables('isUserAssigned'), parameters('userAssignedPrincipalId'), reference(resourceId('Microsoft.Web/sites', parameters('functionAppName')), '2024-04-01', 'full').identity.principalId)]",
        "principalType": "ServicePrincipal"
      },
      "dependsOn": [
        "[resourceId('Microsoft.Web/sites', parameters('functionAppName'))]",
        "[resourceId('Microsoft.KeyVault/vaults', parameters('keyVaultName'))]"
      ]
    }
  ],
  "outputs": {
    "functionAppName": {
      "type": "string",
      "value": "[parameters('functionAppName')]"
    },
    "functionAppHostname": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Web/sites', parameters('functionAppName')), '2024-04-01').defaultHostName]"
    },
    "functionAppPrincipalId": {
      "type": "string",
      "value": "[if(variables('isUserAssigned'), parameters('userAssignedPrincipalId'), reference(resourceId('Microsoft.Web/sites', parameters('functionAppName')), '2024-04-01', 'full').identity.principalId)]"
    },
    "grantAdxIngestorRole": {
      "type": "string",
      "metadata": {
        "description": "Run this KQL command in your ADX cluster to grant the Function App ingest permissions."
      },
      "value": "[format('.add database {0} ingestors (''aadapp={1}'')', parameters('adxDatabaseName'), if(variables('isUserAssigned'), parameters('userAssignedPrincipalId'), reference(resourceId('Microsoft.Web/sites', parameters('functionAppName')), '2024-04-01', 'full').identity.principalId))]"
    },
    "keyVaultUri": {
      "type": "string",
      "value": "[if(equals(parameters('keyVaultOption'), 'create'), reference(resourceId('Microsoft.KeyVault/vaults', parameters('keyVaultName')), '2023-07-01').vaultUri, '')]"
    },
    "grantKeyVaultAccess": {
      "type": "string",
      "metadata": {
        "description": "When using an existing Key Vault, run this command to grant the Function App secret read access."
      },
      "value": "[if(equals(parameters('keyVaultOption'), 'existing'), format('az role assignment create --role \"Key Vault Secrets User\" --assignee {0} --scope {1}', if(variables('isUserAssigned'), parameters('userAssignedPrincipalId'), reference(resourceId('Microsoft.Web/sites', parameters('functionAppName')), '2024-04-01', 'full').identity.principalId), resourceId('Microsoft.KeyVault/vaults', parameters('keyVaultName'))), if(equals(parameters('keyVaultOption'), 'create'), 'Automatically configured via RBAC role assignment.', 'Not applicable - Key Vault not in use.'))]"
    }
  }
}