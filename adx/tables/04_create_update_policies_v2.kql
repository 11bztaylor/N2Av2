// =============================================================================
// 04 — Create Update Policies
// =============================================================================
// Update policies automatically fan out rows from Netskope_Raw into the
// typed tables based on the StreamType column.
//
// When a batch lands in Netskope_Raw, ADX fires each update policy's
// query against the NEW rows only, and appends matching rows to the
// target typed table.
//
// Each policy:
//   Source:  Netskope_Raw
//   Filter:  WHERE StreamType == "events_{type}" (or "alerts_{subtype}")
//   Project: TimeGenerated, RawData  (StreamType is implicit in table name)
//
// Run AFTER 03_create_typed_tables_v2.kql
// =============================================================================


// ---------------------------------------------------------------------------
// Helper functions (one per stream type)
// These are referenced by the update policies below.
// ---------------------------------------------------------------------------

// --- Events ---

.create-or-alter function NetskopeEventsPage_Transform() {
    Netskope_Raw
    | where StreamType == "events_page"
    | project TimeGenerated, RawData
}

.create-or-alter function NetskopeEventsApplication_Transform() {
    Netskope_Raw
    | where StreamType == "events_application"
    | project TimeGenerated, RawData
}

.create-or-alter function NetskopeEventsAudit_Transform() {
    Netskope_Raw
    | where StreamType == "events_audit"
    | project TimeGenerated, RawData
}

