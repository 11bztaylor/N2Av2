    | where StreamType == "events_network"
    | project TimeGenerated, RawData
}

.create-or-alter function NetskopeEventsConnection_Transform() {
    Netskope_Raw
    | where StreamType == "events_connection"
    | project TimeGenerated, RawData
}

.create-or-alter function NetskopeEventsEndpoint_Transform() {
    Netskope_Raw
    | where StreamType == "events_endpoint"
    | project TimeGenerated, RawData
}

.create-or-alter function NetskopeEventsIncident_Transform() {
    Netskope_Raw
    | where StreamType == "events_incident"
    | project TimeGenerated, RawData
}


