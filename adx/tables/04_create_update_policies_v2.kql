// ---------------------------------------------------------------------------
// Update policies
// IsEnabled: true    — policy is active
// IsTransactional: false — don't roll back Netskope_Raw insert if typed insert fails
//                          (we'd rather have data in Raw than lose it entirely)
// PropagateIngestionProperties: true — carry ingestion tags through
// ---------------------------------------------------------------------------

// --- Events ---

.alter table NetskopeEventsPage policy update
@'[{"IsEnabled": true, "Source": "Netskope_Raw", "Query": "NetskopeEventsPage_Transform()", "IsTransactional": false, "PropagateIngestionProperties": true}]'

.alter table NetskopeEventsApplication policy update
@'[{"IsEnabled": true, "Source": "Netskope_Raw", "Query": "NetskopeEventsApplication_Transform()", "IsTransactional": false, "PropagateIngestionProperties": true}]'

.alter table NetskopeEventsAudit policy update
