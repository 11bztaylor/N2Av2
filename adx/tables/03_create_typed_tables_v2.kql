// ---------------------------------------------------------------------------
// Retention: match or exceed Netskope_Raw. Typed tables are canonical.
// ---------------------------------------------------------------------------

// Events: 180 days default (adjust per compliance requirements)
.alter tables (
    NetskopeEventsPage,
    NetskopeEventsApplication,
    NetskopeEventsAudit,
    NetskopeEventsInfrastructure,
    NetskopeEventsNetwork,
    NetskopeEventsConnection,
    NetskopeEventsEndpoint,
    NetskopeEventsIncident
) policy retention
```
{
  "SoftDeletePeriod": "180.00:00:00",
  "Recoverability": "Enabled"
}
```

// Alerts: 365 days default (security data, keep longer)
.alter tables (
    NetskopeAlertsRemediation,
    NetskopeAlertsCompromisedCredential,
    NetskopeAlertsUba,
    NetskopeAlertsSecurityAssessment,
    NetskopeAlertsQuarantine,
    NetskopeAlertsPolicy,
    NetskopeAlertsMalware,
    NetskopeAlertsMalsite,
    NetskopeAlertsDlp,
    NetskopeAlertsCtep,
    NetskopeAlertsWatchlist,
    NetskopeAlertsDevice,
    NetskopeAlertsContent
) policy retention
```
{
  "SoftDeletePeriod": "365.00:00:00",
  "Recoverability": "Enabled"
}
```
