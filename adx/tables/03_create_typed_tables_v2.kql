// =============================================================================
// 03 — Create Typed Tables
// =============================================================================
// One table per event type and alert subtype, populated by update policies.
//
// Schema: TimeGenerated (datetime) + RawData (dynamic)
//   - StreamType is implicit in the table name, so we don't duplicate it.
//   - RawData holds the full Netskope payload as a dynamic column.
//   - Query specific fields with: | extend user = tostring(RawData.user)
//
// This is the ADX-native approach: store raw, query flexibly.
// No need to maintain per-type column schemas (a Sentinel constraint
// that no longer applies).
//
// Run AFTER 02_create_mapping_v2.kql
// =============================================================================

// ---------------------------------------------------------------------------
// Event tables
// ---------------------------------------------------------------------------

.create-merge table NetskopeEventsPage (
    TimeGenerated: datetime,
    RawData:       dynamic
)
.alter table NetskopeEventsPage folder "Netskope/Events"

.create-merge table NetskopeEventsApplication (
    TimeGenerated: datetime,
    RawData:       dynamic
)
.alter table NetskopeEventsApplication folder "Netskope/Events"

.create-merge table NetskopeEventsAudit (
    TimeGenerated: datetime,
    RawData:       dynamic
)
.alter table NetskopeEventsAudit folder "Netskope/Events"

.create-merge table NetskopeEventsInfrastructure (
    TimeGenerated: datetime,
    RawData:       dynamic
)
.alter table NetskopeEventsInfrastructure folder "Netskope/Events"

.create-merge table NetskopeEventsNetwork (
    TimeGenerated: datetime,
    RawData:       dynamic
)
.alter table NetskopeEventsNetwork folder "Netskope/Events"

.create-merge table NetskopeEventsConnection (
    TimeGenerated: datetime,
    RawData:       dynamic
)
.alter table NetskopeEventsConnection folder "Netskope/Events"

.create-merge table NetskopeEventsEndpoint (
    TimeGenerated: datetime,
    RawData:       dynamic
)
.alter table NetskopeEventsEndpoint folder "Netskope/Events"

.create-merge table NetskopeEventsIncident (
    TimeGenerated: datetime,
    RawData:       dynamic
)
.alter table NetskopeEventsIncident folder "Netskope/Events"


