{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "2.0.0.0",

  "parameters": {
    "functionAppName": {
      "type": "string",
      "metadata": { "description": "Name of the Azure Function App." }
    },
    "storageAccountName": {
      "type": "string",
      "maxLength": 24,
      "metadata": { "description": "Lowercase, no hyphens, max 24 chars. Must be globally unique." }
    },
    "appInsightsName": {
      "type": "string",
      "metadata": { "description": "Name of the Application Insights instance." }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": { "description": "Azure region for all resources." }
    },
    "pythonVersion": {
      "type": "string",
      "defaultValue": "3.12",
      "allowedValues": [ "3.10", "3.11", "3.12" ],
      "metadata": { "description": "Python runtime version. 3.12 recommended." }
    },
    "managedIdentityType": {
      "type": "string",
      "defaultValue": "SystemAssigned",
      "allowedValues": [ "SystemAssigned", "UserAssigned" ],
      "metadata": { "description": "Type of managed identity for ADX auth." }
    },
    "userAssignedIdentityResourceId": {
      "type": "string",
      "defaultValue": "",
      "metadata": { "description": "Resource ID of the UAMI. Required if managedIdentityType is UserAssigned." }
    },

    "adxClusterUri": {
      "type": "string",
      "metadata": { "description": "ADX query endpoint, e.g. https://<cluster>.<region>.kusto.windows.net" }
    },
    "adxDatabaseName": {
      "type": "string",
      "metadata": { "description": "Target ADX database name." }
    },

    "netskopeHostname": {
      "type": "string",
      "metadata": { "description": "Netskope tenant hostname, e.g. mytenant.goskope.com" }
    },
    "netskopeApiToken": {
      "type": "securestring",
      "metadata": { "description": "Netskope REST API v2 token." }
    },
    "netskopeIndex": {
      "type": "string",
      "defaultValue": "NetskopeADX",
      "metadata": { "description": "Base iterator index name. Per-stream suffix appended automatically." }
    },
    "logLevel": {
      "type": "string",
      "defaultValue": "INFO",
      "allowedValues": [ "DEBUG", "INFO", "WARNING", "ERROR" ],
      "metadata": { "description": "Python logging level." }
    },

    "ingestEventsPage":           { "type": "string", "defaultValue": "Yes", "allowedValues": ["Yes","No"], "metadata": { "description": "Ingest page events." } },
    "ingestEventsApplication":    { "type": "string", "defaultValue": "Yes", "allowedValues": ["Yes","No"], "metadata": { "description": "Ingest application events." } },
    "ingestEventsAudit":          { "type": "string", "defaultValue": "Yes", "allowedValues": ["Yes","No"], "metadata": { "description": "Ingest audit events." } },
    "ingestEventsInfrastructure":  { "type": "string", "defaultValue": "No",  "allowedValues": ["Yes","No"], "metadata": { "description": "Ingest infrastructure events." } },
    "ingestEventsNetwork":        { "type": "string", "defaultValue": "No",  "allowedValues": ["Yes","No"], "metadata": { "description": "Ingest network events." } },
    "ingestEventsConnection":     { "type": "string", "defaultValue": "No",  "allowedValues": ["Yes","No"], "metadata": { "description": "Ingest connection events." } },
    "ingestEventsEndpoint":       { "type": "string", "defaultValue": "No",  "allowedValues": ["Yes","No"], "metadata": { "description": "Ingest endpoint events." } },

    "ingestAlertsRemediation":            { "type": "string", "defaultValue": "No",  "allowedValues": ["Yes","No"], "metadata": { "description": "Ingest remediation alerts." } },
    "ingestAlertsCompromisedCredential":  { "type": "string", "defaultValue": "No",  "allowedValues": ["Yes","No"], "metadata": { "description": "Ingest compromised credential alerts." } },
    "ingestAlertsUba":                    { "type": "string", "defaultValue": "No",  "allowedValues": ["Yes","No"], "metadata": { "description": "Ingest UBA alerts." } },
    "ingestAlertsSecurityAssessment":     { "type": "string", "defaultValue": "No",  "allowedValues": ["Yes","No"], "metadata": { "description": "Ingest security assessment alerts." } },
    "ingestAlertsQuarantine":             { "type": "string", "defaultValue": "No",  "allowedValues": ["Yes","No"], "metadata": { "description": "Ingest quarantine alerts." } },
    "ingestAlertsPolicy":                 { "type": "string", "defaultValue": "Yes", "allowedValues": ["Yes","No"], "metadata": { "description": "Ingest policy alerts." } },
    "ingestAlertsMalware":                { "type": "string", "defaultValue": "Yes", "allowedValues": ["Yes","No"], "metadata": { "description": "Ingest malware alerts." } },
    "ingestAlertsMalsite":                { "type": "string", "defaultValue": "Yes", "allowedValues": ["Yes","No"], "metadata": { "description": "Ingest malsite alerts." } },
    "ingestAlertsDlp":                    { "type": "string", "defaultValue": "Yes", "allowedValues": ["Yes","No"], "metadata": { "description": "Ingest DLP alerts." } },
    "ingestAlertsCtep":                   { "type": "string", "defaultValue": "No",  "allowedValues": ["Yes","No"], "metadata": { "description": "Ingest CTEP alerts." } },
    "ingestAlertsWatchlist":               { "type": "string", "defaultValue": "No",  "allowedValues": ["Yes","No"], "metadata": { "description": "Ingest watchlist alerts." } },
    "ingestAlertsDevice":                  { "type": "string", "defaultValue": "No",  "allowedValues": ["Yes","No"], "metadata": { "description": "Ingest device alerts." } },
    "ingestAlertsContent":                 { "type": "string", "defaultValue": "No",  "allowedValues": ["Yes","No"], "metadata": { "description": "Ingest content alerts." } },

    "ingestEventsIncident":                { "type": "string", "defaultValue": "No",  "allowedValues": ["Yes","No"], "metadata": { "description": "Ingest incident events." } }
  },

  "variables": {
    "hostingPlanName": "[concat(parameters('functionAppName'), '-plan')]",
    "storageConnectionString": "[concat('DefaultEndpointsProtocol=https;AccountName=', parameters('storageAccountName'), ';AccountKey=', listKeys(resourceId('Microsoft.Storage/storageAccounts', parameters('storageAccountName')), '2024-01-01').keys[0].value, ';EndpointSuffix=core.windows.net')]",
    "isUserAssigned": "[equals(parameters('managedIdentityType'), 'UserAssigned')]",
    "identityBlock": "[if(variables('isUserAssigned'), json(concat('{\"type\":\"UserAssigned\",\"userAssignedIdentities\":{\"', parameters('userAssignedIdentityResourceId'), '\":{}}}')), json('{\"type\":\"SystemAssigned\"}'))]"
  },

  "resources": [
    {
      "type": "Microsoft.Storage/storageAccounts",
      "apiVersion": "2024-01-01",
      "name": "[parameters('storageAccountName')]",
      "location": "[parameters('location')]",
      "sku": { "name": "Standard_LRS" },
      "kind": "StorageV2",
      "properties": {
        "supportsHttpsTrafficOnly": true,
        "minimumTlsVersion": "TLS1_2",
        "allowBlobPublicAccess": false
      }
    },
    {
      "type": "Microsoft.Insights/components",
      "apiVersion": "2020-02-02",
      "name": "[parameters('appInsightsName')]",
      "location": "[parameters('location')]",
      "kind": "web",
      "properties": {
        "Application_Type": "web",
        "Request_Source": "rest"
      }
    },
    {
      "type": "Microsoft.Web/serverfarms",
      "apiVersion": "2024-04-01",
      "name": "[variables('hostingPlanName')]",
      "location": "[parameters('location')]",
      "kind": "linux",
      "sku": { "name": "Y1", "tier": "Dynamic" },
      "properties": { "reserved": true }
    },
    {
      "type": "Microsoft.Web/sites",
      "apiVersion": "2024-04-01",
      "name": "[parameters('functionAppName')]",
      "location": "[parameters('location')]",
      "kind": "functionapp,linux",
      "identity": "[variables('identityBlock')]",
      "dependsOn": [
        "[resourceId('Microsoft.Web/serverfarms', variables('hostingPlanName'))]",
        "[resourceId('Microsoft.Storage/storageAccounts', parameters('storageAccountName'))]",
        "[resourceId('Microsoft.Insights/components', parameters('appInsightsName'))]"
      ],
      "properties": {
        "serverFarmId": "[resourceId('Microsoft.Web/serverfarms', variables('hostingPlanName'))]",
        "reserved": true,
        "httpsOnly": true,
        "siteConfig": {
          "linuxFxVersion": "[concat('PYTHON|', parameters('pythonVersion'))]",
          "ftpsState": "Disabled",
          "minTlsVersion": "1.2",
          "appSettings": [
            { "name": "FUNCTIONS_EXTENSION_VERSION",            "value": "~4" },
            { "name": "FUNCTIONS_WORKER_RUNTIME",               "value": "python" },
            { "name": "AzureWebJobsStorage",                    "value": "[variables('storageConnectionString')]" },
            { "name": "APPINSIGHTS_INSTRUMENTATIONKEY",         "value": "[reference(resourceId('Microsoft.Insights/components', parameters('appInsightsName'))).InstrumentationKey]" },
            { "name": "APPLICATIONINSIGHTS_CONNECTION_STRING",  "value": "[reference(resourceId('Microsoft.Insights/components', parameters('appInsightsName'))).ConnectionString]" },

            { "name": "ADX_CLUSTER_URI",    "value": "[parameters('adxClusterUri')]" },
            { "name": "ADX_DATABASE",       "value": "[parameters('adxDatabaseName')]" },

            { "name": "NetskopeHostname",   "value": "[parameters('netskopeHostname')]" },
            { "name": "NetskopeApiToken",   "value": "[parameters('netskopeApiToken')]" },
            { "name": "NetskopeIndex",      "value": "[parameters('netskopeIndex')]" },
            { "name": "LOG_LEVEL",          "value": "[parameters('logLevel')]" },

            { "name": "IngestEventsPage",           "value": "[parameters('ingestEventsPage')]" },
            { "name": "IngestEventsApplication",    "value": "[parameters('ingestEventsApplication')]" },
            { "name": "IngestEventsAudit",          "value": "[parameters('ingestEventsAudit')]" },
            { "name": "IngestEventsInfrastructure", "value": "[parameters('ingestEventsInfrastructure')]" },
            { "name": "IngestEventsNetwork",        "value": "[parameters('ingestEventsNetwork')]" },
            { "name": "IngestEventsConnection",     "value": "[parameters('ingestEventsConnection')]" },
            { "name": "IngestEventsEndpoint",       "value": "[parameters('ingestEventsEndpoint')]" },
            { "name": "IngestEventsIncident",       "value": "[parameters('ingestEventsIncident')]" },

            { "name": "IngestAlertsRemediation",           "value": "[parameters('ingestAlertsRemediation')]" },
            { "name": "IngestAlertsCompromisedCredential", "value": "[parameters('ingestAlertsCompromisedCredential')]" },
            { "name": "IngestAlertsUba",                   "value": "[parameters('ingestAlertsUba')]" },
            { "name": "IngestAlertsSecurityAssessment",    "value": "[parameters('ingestAlertsSecurityAssessment')]" },
            { "name": "IngestAlertsQuarantine",            "value": "[parameters('ingestAlertsQuarantine')]" },
            { "name": "IngestAlertsPolicy",                "value": "[parameters('ingestAlertsPolicy')]" },
            { "name": "IngestAlertsMalware",               "value": "[parameters('ingestAlertsMalware')]" },
            { "name": "IngestAlertsMalsite",               "value": "[parameters('ingestAlertsMalsite')]" },
            { "name": "IngestAlertsDlp",                   "value": "[parameters('ingestAlertsDlp')]" },
            { "name": "IngestAlertsCtep",                  "value": "[parameters('ingestAlertsCtep')]" },
            { "name": "IngestAlertsWatchlist",              "value": "[parameters('ingestAlertsWatchlist')]" },
            { "name": "IngestAlertsDevice",                 "value": "[parameters('ingestAlertsDevice')]" },
            { "name": "IngestAlertsContent",                "value": "[parameters('ingestAlertsContent')]" }
          ]
        }
      }
    }
  ],

  "outputs": {
    "functionAppName": {
      "type": "string",
      "value": "[parameters('functionAppName')]"
    },
    "functionAppPrincipalId": {
      "type": "string",
      "value": "[if(variables('isUserAssigned'), reference(parameters('userAssignedIdentityResourceId'), '2023-01-31').principalId, reference(resourceId('Microsoft.Web/sites', parameters('functionAppName')), '2024-04-01', 'Full').identity.principalId)]"
    },
    "functionAppHostname": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Web/sites', parameters('functionAppName'))).defaultHostName]"
    },
    "grantAdxIngestorRole": {
      "type": "string",
      "value": "[concat('.add database ', parameters('adxDatabaseName'), ' ingestors (''aadapp=', if(variables('isUserAssigned'), reference(parameters('userAssignedIdentityResourceId'), '2023-01-31').principalId, reference(resourceId('Microsoft.Web/sites', parameters('functionAppName')), '2024-04-01', 'Full').identity.principalId), ''')')]"
    }
  }
}
