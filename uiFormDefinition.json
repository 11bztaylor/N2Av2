{
  "$schema": "https://schema.management.azure.com/schemas/2021-09-09/uiFormDefinition.schema.json",
  "view": {
    "kind": "Form",
    "properties": {
      "title": "Netskope to ADX — Log Ingestion",
      "steps": [
        {
          "name": "basics",
          "label": "Basics",
          "elements": [
            {
              "name": "resourceScope",
              "type": "Microsoft.Common.ResourceScope",
              "location": {
                "resourceTypes": [
                  "microsoft.resources/resourcegroups"
                ]
              }
            },
            {
              "name": "functionAppName",
              "type": "Microsoft.Common.TextBox",
              "label": "Function App Name",
              "toolTip": "Globally unique name for the Azure Function App.",
              "constraints": {
                "required": true,
                "regex": "^[a-zA-Z0-9-]{2,60}$",
                "validationMessage": "2-60 characters, letters, numbers, and hyphens only."
              }
            },
            {
              "name": "storageAccountName",
              "type": "Microsoft.Common.TextBox",
              "label": "Storage Account Name",
              "toolTip": "Globally unique. Lowercase letters and numbers only, 3-24 characters.",
              "constraints": {
                "required": true,
                "regex": "^[a-z0-9]{3,24}$",
                "validationMessage": "3-24 characters, lowercase letters and numbers only. No hyphens."
              }
            },
            {
              "name": "appInsightsName",
              "type": "Microsoft.Common.TextBox",
              "label": "Application Insights Name",
              "toolTip": "Name for the Application Insights monitoring instance.",
              "constraints": {
                "required": true
              }
            }
          ]
        },
        {
          "name": "netskopeConfig",
          "label": "Netskope",
          "elements": [
            {
              "name": "netskopeHostname",
              "type": "Microsoft.Common.TextBox",
              "label": "Netskope Tenant Hostname",
              "toolTip": "Your Netskope tenant FQDN, e.g., mytenant.goskope.com",
              "placeholder": "mytenant.goskope.com",
              "constraints": {
                "required": true
              }
            },
            {
              "name": "netskopeApiToken",
              "type": "Microsoft.Common.PasswordBox",
              "label": {
                "password": "Netskope API Token",
                "confirmPassword": "Confirm Token"
              },
              "toolTip": "REST API v2 token with dataexport read/write permissions.",
              "constraints": {
                "required": true
              },
              "options": {
                "hideConfirmation": true
              }
            },
            {
              "name": "netskopeIndex",
              "type": "Microsoft.Common.TextBox",
              "label": "Iterator Index Name",
              "toolTip": "Shared across all endpoints. Netskope scopes the cursor per endpoint automatically. WARNING: Changing after deployment may cause data gaps.",
              "defaultValue": "NetskopeADX",
              "constraints": {
                "required": true
              }
            }
          ]
        },
        {
          "name": "adxConfig",
          "label": "ADX Configuration",
          "elements": [
            {
              "name": "adxClusterSelector",
              "type": "Microsoft.Solutions.ResourceSelector",
              "label": "ADX Cluster",
              "toolTip": "Select your Azure Data Explorer cluster.",
              "resourceType": "Microsoft.Kusto/clusters",
              "options": {
                "filter": {
                  "subscription": "onBasics"
                }
              }
            },
            {
              "name": "adxClusterDetailsApi",
              "type": "Microsoft.Solutions.ArmApiControl",
              "request": {
                "method": "GET",
                "path": "[concat(steps('adxConfig').adxClusterSelector.id, '?api-version=2023-08-15')]"
              }
            },
            {
              "name": "adxDatabasesApi",
              "type": "Microsoft.Solutions.ArmApiControl",
              "request": {
                "method": "GET",
                "path": "[concat(steps('adxConfig').adxClusterSelector.id, '/databases?api-version=2023-08-15')]"
              }
            },
            {
              "name": "adxDatabaseName",
              "type": "Microsoft.Common.DropDown",
              "label": "ADX Database",
              "toolTip": "Select the target database for Netskope data ingestion. Pick a cluster above first.",
              "constraints": {
                "required": true,
                "allowedValues": "[map(steps('adxConfig').adxDatabasesApi.value, (db) => parse(concat('{\"label\":\"', last(split(db.name, '/')), '\",\"value\":\"', last(split(db.name, '/')), '\"}')))]"
              },
              "visible": true
            }
          ]
        },
        {
          "name": "identitySecurity",
          "label": "Identity & Security",
          "elements": [
            {
              "name": "managedIdentityType",
              "type": "Microsoft.Common.DropDown",
              "label": "Managed Identity Type",
              "toolTip": "SystemAssigned is simpler and auto-managed. UserAssigned gives more control and survives redeploys.",
              "defaultValue": "SystemAssigned",
              "constraints": {
                "required": true,
                "allowedValues": [
                  { "label": "SystemAssigned", "value": "SystemAssigned" },
                  { "label": "UserAssigned", "value": "UserAssigned" }
                ]
              }
            },
            {
              "name": "uamiSelector",
              "type": "Microsoft.Solutions.ResourceSelector",
              "label": "User Assigned Managed Identity",
              "toolTip": "Select the User Assigned Managed Identity. Resource ID, Principal ID, and Client ID are read automatically.",
              "resourceType": "Microsoft.ManagedIdentity/userAssignedIdentities",
              "visible": "[equals(steps('identitySecurity').managedIdentityType, 'UserAssigned')]",
              "options": {
                "filter": {
                  "subscription": "onBasics"
                }
              }
            },
            {
              "name": "uamiDetailsApi",
              "type": "Microsoft.Solutions.ArmApiControl",
              "request": {
                "method": "GET",
                "path": "[concat(steps('identitySecurity').uamiSelector.id, '?api-version=2023-01-31')]"
              }
            },
            {
              "name": "keyVaultInfo",
              "type": "Microsoft.Common.InfoBox",
              "options": {
                "text": "Configure how the Netskope API token is stored. Creating a new Key Vault is recommended for production.",
                "style": "Info"
              }
            },
            {
              "name": "keyVaultOption",
              "type": "Microsoft.Common.DropDown",
              "label": "API Token Storage",
              "toolTip": "How to store the Netskope API token. 'Create' deploys a new Key Vault. 'Existing' references your own. 'None' stores as plaintext (dev/test only).",
              "defaultValue": "Create new Key Vault",
              "constraints": {
                "required": true,
                "allowedValues": [
                  { "label": "Create new Key Vault", "value": "create" },
                  { "label": "Use existing Key Vault", "value": "existing" },
                  { "label": "None (plaintext - dev/test only)", "value": "none" }
                ]
              }
            },
            {
              "name": "existingKeyVaultSelector",
              "type": "Microsoft.Solutions.ResourceSelector",
              "label": "Select Key Vault",
              "toolTip": "Choose an existing Key Vault from your subscription.",
              "resourceType": "Microsoft.KeyVault/vaults",
              "visible": "[equals(steps('identitySecurity').keyVaultOption, 'existing')]",
              "options": {
                "filter": {
                  "subscription": "onBasics"
                }
              }
            },
            {
              "name": "newKeyVaultName",
              "type": "Microsoft.Common.TextBox",
              "label": "New Key Vault Name",
              "toolTip": "Globally unique, 3-24 characters.",
              "defaultValue": "",
              "visible": "[equals(steps('identitySecurity').keyVaultOption, 'create')]",
              "constraints": {
                "required": "[equals(steps('identitySecurity').keyVaultOption, 'create')]",
                "regex": "^[a-zA-Z][a-zA-Z0-9-]{1,22}[a-zA-Z0-9]$",
                "validationMessage": "3-24 characters. Start with letter, end with letter/number. Letters, numbers, hyphens only."
              }
            },
            {
              "name": "keyVaultSecretName",
              "type": "Microsoft.Common.TextBox",
              "label": "Secret Name",
              "toolTip": "Name of the secret in Key Vault.",
              "defaultValue": "NetskopeApiToken",
              "visible": "[not(equals(steps('identitySecurity').keyVaultOption, 'none'))]"
            },
            {
              "name": "keyVaultSku",
              "type": "Microsoft.Common.DropDown",
              "label": "Key Vault SKU",
              "toolTip": "Standard is sufficient. Premium adds HSM-backed keys (not needed).",
              "defaultValue": "standard",
              "visible": "[equals(steps('identitySecurity').keyVaultOption, 'create')]",
              "constraints": {
                "allowedValues": [
                  { "label": "standard", "value": "standard" },
                  { "label": "premium", "value": "premium" }
                ]
              }
            }
          ]
        },
        {
          "name": "eventStreams",
          "label": "Event Streams",
          "elements": [
            {
              "name": "eventsInfo",
              "type": "Microsoft.Common.InfoBox",
              "options": {
                "text": "Event streams capture user and system activity. Each enabled stream polls Netskope every 5 minutes. All default to Yes.",
                "style": "Info"
              }
            },
            {
              "name": "ingestEventsPage",
              "type": "Microsoft.Common.DropDown",
              "label": "Page Events",
              "toolTip": "Web page access events. Typically highest volume.",
              "defaultValue": "Yes",
              "constraints": { "required": true, "allowedValues": [{ "label": "Yes", "value": "Yes" }, { "label": "No", "value": "No" }] }
            },
            {
              "name": "ingestEventsApplication",
              "type": "Microsoft.Common.DropDown",
              "label": "Application Events",
              "toolTip": "Cloud app activity events (SaaS security, shadow IT).",
              "defaultValue": "Yes",
              "constraints": { "required": true, "allowedValues": [{ "label": "Yes", "value": "Yes" }, { "label": "No", "value": "No" }] }
            },
            {
              "name": "ingestEventsAudit",
              "type": "Microsoft.Common.DropDown",
              "label": "Audit Events",
              "toolTip": "Admin audit trail for compliance and change tracking.",
              "defaultValue": "Yes",
              "constraints": { "required": true, "allowedValues": [{ "label": "Yes", "value": "Yes" }, { "label": "No", "value": "No" }] }
            },
            {
              "name": "ingestEventsInfrastructure",
              "type": "Microsoft.Common.DropDown",
              "label": "Infrastructure Events",
              "toolTip": "CASB/SWG platform-level diagnostics.",
              "defaultValue": "Yes",
              "constraints": { "required": true, "allowedValues": [{ "label": "Yes", "value": "Yes" }, { "label": "No", "value": "No" }] }
            },
            {
              "name": "ingestEventsNetwork",
              "type": "Microsoft.Common.DropDown",
              "label": "Network Events",
              "toolTip": "Firewall and IPS events (Netskope Intelligent SSE).",
              "defaultValue": "Yes",
              "constraints": { "required": true, "allowedValues": [{ "label": "Yes", "value": "Yes" }, { "label": "No", "value": "No" }] }
            },
            {
              "name": "ingestEventsConnection",
              "type": "Microsoft.Common.DropDown",
              "label": "Connection Events",
              "toolTip": "Tunnel and ZTNA connection events.",
              "defaultValue": "Yes",
              "constraints": { "required": true, "allowedValues": [{ "label": "Yes", "value": "Yes" }, { "label": "No", "value": "No" }] }
            },
            {
              "name": "ingestEventsEndpoint",
              "type": "Microsoft.Common.DropDown",
              "label": "Endpoint Events",
              "toolTip": "NPA client and device posture events.",
              "defaultValue": "Yes",
              "constraints": { "required": true, "allowedValues": [{ "label": "Yes", "value": "Yes" }, { "label": "No", "value": "No" }] }
            },
            {
              "name": "ingestEventsIncident",
              "type": "Microsoft.Common.DropDown",
              "label": "Incident Events",
              "toolTip": "Security incident events. May not be available on all licenses.",
              "defaultValue": "Yes",
              "constraints": { "required": true, "allowedValues": [{ "label": "Yes", "value": "Yes" }, { "label": "No", "value": "No" }] }
            }
          ]
        },
        {
          "name": "alertStreams",
          "label": "Alert Streams",
          "elements": [
            {
              "name": "alertsInfo",
              "type": "Microsoft.Common.InfoBox",
              "options": {
                "text": "Alert streams capture security alerts. These use 365-day retention in ADX (vs 180 days for events). All default to Yes.",
                "style": "Info"
              }
            },
            {
              "name": "ingestAlertsPolicy",
              "type": "Microsoft.Common.DropDown",
              "label": "Policy Alerts",
              "toolTip": "Real-time policy violation alerts.",
              "defaultValue": "Yes",
              "constraints": { "required": true, "allowedValues": [{ "label": "Yes", "value": "Yes" }, { "label": "No", "value": "No" }] }
            },
            {
              "name": "ingestAlertsDlp",
              "type": "Microsoft.Common.DropDown",
              "label": "DLP Alerts",
              "toolTip": "Data Loss Prevention alerts.",
              "defaultValue": "Yes",
              "constraints": { "required": true, "allowedValues": [{ "label": "Yes", "value": "Yes" }, { "label": "No", "value": "No" }] }
            },
            {
              "name": "ingestAlertsMalware",
              "type": "Microsoft.Common.DropDown",
              "label": "Malware Alerts",
              "toolTip": "Malware detection alerts (cloud + inline scan).",
              "defaultValue": "Yes",
              "constraints": { "required": true, "allowedValues": [{ "label": "Yes", "value": "Yes" }, { "label": "No", "value": "No" }] }
            },
            {
              "name": "ingestAlertsMalsite",
              "type": "Microsoft.Common.DropDown",
              "label": "Malicious Site Alerts",
              "toolTip": "Malicious URL/site alerts.",
              "defaultValue": "Yes",
              "constraints": { "required": true, "allowedValues": [{ "label": "Yes", "value": "Yes" }, { "label": "No", "value": "No" }] }
            },
            {
              "name": "ingestAlertsRemediation",
              "type": "Microsoft.Common.DropDown",
              "label": "Remediation Alerts",
              "toolTip": "Quarantine, block, and coach action alerts.",
              "defaultValue": "Yes",
              "constraints": { "required": true, "allowedValues": [{ "label": "Yes", "value": "Yes" }, { "label": "No", "value": "No" }] }
            },
            {
              "name": "ingestAlertsCompromisedCredential",
              "type": "Microsoft.Common.DropDown",
              "label": "Compromised Credential Alerts",
              "toolTip": "Compromised credential alerts. Requires threat protection license.",
              "defaultValue": "Yes",
              "constraints": { "required": true, "allowedValues": [{ "label": "Yes", "value": "Yes" }, { "label": "No", "value": "No" }] }
            },
            {
              "name": "ingestAlertsUba",
              "type": "Microsoft.Common.DropDown",
              "label": "UBA Alerts",
              "toolTip": "User Behavior Analytics alerts for insider threat detection.",
              "defaultValue": "Yes",
              "constraints": { "required": true, "allowedValues": [{ "label": "Yes", "value": "Yes" }, { "label": "No", "value": "No" }] }
            },
            {
              "name": "ingestAlertsSecurityAssessment",
              "type": "Microsoft.Common.DropDown",
              "label": "Security Assessment Alerts",
              "toolTip": "Security posture assessment alerts (CSPM).",
              "defaultValue": "Yes",
              "constraints": { "required": true, "allowedValues": [{ "label": "Yes", "value": "Yes" }, { "label": "No", "value": "No" }] }
            },
            {
              "name": "ingestAlertsQuarantine",
              "type": "Microsoft.Common.DropDown",
              "label": "Quarantine Alerts",
              "toolTip": "File quarantine action alerts.",
              "defaultValue": "Yes",
              "constraints": { "required": true, "allowedValues": [{ "label": "Yes", "value": "Yes" }, { "label": "No", "value": "No" }] }
            },
            {
              "name": "ingestAlertsCtep",
              "type": "Microsoft.Common.DropDown",
              "label": "CTEP Alerts",
              "toolTip": "Client Traffic Exploit Prevention alerts.",
              "defaultValue": "Yes",
              "constraints": { "required": true, "allowedValues": [{ "label": "Yes", "value": "Yes" }, { "label": "No", "value": "No" }] }
            },
            {
              "name": "ingestAlertsWatchlist",
              "type": "Microsoft.Common.DropDown",
              "label": "Watchlist Alerts",
              "toolTip": "Alerts for monitored users/entities.",
              "defaultValue": "Yes",
              "constraints": { "required": true, "allowedValues": [{ "label": "Yes", "value": "Yes" }, { "label": "No", "value": "No" }] }
            },
            {
              "name": "ingestAlertsDevice",
              "type": "Microsoft.Common.DropDown",
              "label": "Device Alerts",
              "toolTip": "Device classification/compliance alerts.",
              "defaultValue": "Yes",
              "constraints": { "required": true, "allowedValues": [{ "label": "Yes", "value": "Yes" }, { "label": "No", "value": "No" }] }
            },
            {
              "name": "ingestAlertsContent",
              "type": "Microsoft.Common.DropDown",
              "label": "Content Alerts",
              "toolTip": "Content classification/inspection alerts.",
              "defaultValue": "Yes",
              "constraints": { "required": true, "allowedValues": [{ "label": "Yes", "value": "Yes" }, { "label": "No", "value": "No" }] }
            }
          ]
        },
        {
          "name": "advanced",
          "label": "Advanced",
          "elements": [
            {
              "name": "pythonVersion",
              "type": "Microsoft.Common.DropDown",
              "label": "Python Version",
              "toolTip": "3.12 recommended for performance and security patches.",
              "defaultValue": "3.12 (Recommended)",
              "constraints": {
                "required": true,
                "allowedValues": [
                  { "label": "3.12 (Recommended)", "value": "3.12" },
                  { "label": "3.11", "value": "3.11" },
                  { "label": "3.10", "value": "3.10" }
                ]
              }
            },
            {
              "name": "logLevel",
              "type": "Microsoft.Common.DropDown",
              "label": "Log Level",
              "toolTip": "Application log verbosity.",
              "defaultValue": "INFO (recommended)",
              "constraints": {
                "required": true,
                "allowedValues": [
                  { "label": "DEBUG (very verbose)", "value": "DEBUG" },
                  { "label": "INFO (recommended)", "value": "INFO" },
                  { "label": "WARNING (quiet)", "value": "WARNING" },
                  { "label": "ERROR (errors only)", "value": "ERROR" }
                ]
              }
            },
            {
              "name": "detailedKustoLogging",
              "type": "Microsoft.Common.DropDown",
              "label": "Detailed Kusto SDK Logging",
              "toolTip": "Enable verbose ADX connection and ingestion logs for troubleshooting.",
              "defaultValue": "No (recommended)",
              "constraints": {
                "required": true,
                "allowedValues": [
                  { "label": "Yes", "value": "Yes" },
                  { "label": "No (recommended)", "value": "No" }
                ]
              }
            }
          ]
        }
      ]
    },
    "outputs": {
      "parameters": {
        "functionAppName": "[steps('basics').functionAppName]",
        "storageAccountName": "[steps('basics').storageAccountName]",
        "appInsightsName": "[steps('basics').appInsightsName]",
        "location": "[steps('basics').resourceScope.location.name]",

        "netskopeHostname": "[steps('netskopeConfig').netskopeHostname]",
        "netskopeApiToken": "[steps('netskopeConfig').netskopeApiToken]",
        "netskopeIndex": "[steps('netskopeConfig').netskopeIndex]",

        "adxClusterUri": "[steps('adxConfig').adxClusterDetailsApi.properties.uri]",
        "adxDatabaseName": "[steps('adxConfig').adxDatabaseName]",

        "managedIdentityType": "[steps('identitySecurity').managedIdentityType]",
        "userAssignedIdentityResourceId": "[if(equals(steps('identitySecurity').managedIdentityType, 'UserAssigned'), steps('identitySecurity').uamiSelector.id, '')]",
        "userAssignedPrincipalId": "[if(equals(steps('identitySecurity').managedIdentityType, 'UserAssigned'), steps('identitySecurity').uamiDetailsApi.properties.principalId, '')]",
        "userAssignedClientId": "[if(equals(steps('identitySecurity').managedIdentityType, 'UserAssigned'), steps('identitySecurity').uamiDetailsApi.properties.clientId, '')]",
        "keyVaultOption": "[steps('identitySecurity').keyVaultOption]",
        "keyVaultName": "[if(equals(steps('identitySecurity').keyVaultOption, 'existing'), steps('identitySecurity').existingKeyVaultSelector.name, steps('identitySecurity').newKeyVaultName)]",
        "keyVaultSecretName": "[steps('identitySecurity').keyVaultSecretName]",
        "keyVaultSku": "[steps('identitySecurity').keyVaultSku]",

        "ingestEventsPage": "[steps('eventStreams').ingestEventsPage]",
        "ingestEventsApplication": "[steps('eventStreams').ingestEventsApplication]",
        "ingestEventsAudit": "[steps('eventStreams').ingestEventsAudit]",
        "ingestEventsInfrastructure": "[steps('eventStreams').ingestEventsInfrastructure]",
        "ingestEventsNetwork": "[steps('eventStreams').ingestEventsNetwork]",
        "ingestEventsConnection": "[steps('eventStreams').ingestEventsConnection]",
        "ingestEventsEndpoint": "[steps('eventStreams').ingestEventsEndpoint]",
        "ingestEventsIncident": "[steps('eventStreams').ingestEventsIncident]",

        "ingestAlertsPolicy": "[steps('alertStreams').ingestAlertsPolicy]",
        "ingestAlertsDlp": "[steps('alertStreams').ingestAlertsDlp]",
        "ingestAlertsMalware": "[steps('alertStreams').ingestAlertsMalware]",
        "ingestAlertsMalsite": "[steps('alertStreams').ingestAlertsMalsite]",
        "ingestAlertsRemediation": "[steps('alertStreams').ingestAlertsRemediation]",
        "ingestAlertsCompromisedCredential": "[steps('alertStreams').ingestAlertsCompromisedCredential]",
        "ingestAlertsUba": "[steps('alertStreams').ingestAlertsUba]",
        "ingestAlertsSecurityAssessment": "[steps('alertStreams').ingestAlertsSecurityAssessment]",
        "ingestAlertsQuarantine": "[steps('alertStreams').ingestAlertsQuarantine]",
        "ingestAlertsCtep": "[steps('alertStreams').ingestAlertsCtep]",
        "ingestAlertsWatchlist": "[steps('alertStreams').ingestAlertsWatchlist]",
        "ingestAlertsDevice": "[steps('alertStreams').ingestAlertsDevice]",
        "ingestAlertsContent": "[steps('alertStreams').ingestAlertsContent]",

        "pythonVersion": "[steps('advanced').pythonVersion]",
        "logLevel": "[steps('advanced').logLevel]",
        "detailedKustoLogging": "[steps('advanced').detailedKustoLogging]"
      },
      "kind": "ResourceGroup",
      "location": "[steps('basics').resourceScope.location.name]",
      "resourceGroupId": "[steps('basics').resourceScope.resourceGroup.id]"
    }
  }
}